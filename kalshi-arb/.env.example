# Copy to .env and fill in. Never commit .env.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./kalshi-private-key.pem
KALSHI_USE_DEMO=true

# Hard gate for live trading — must be explicitly set to "true"
LIVE_TRADING=false

# Kill switch file path (presence = trading halted)
KILL_SWITCH_FILE=./KILL_SWITCH

# Daily loss limit (USD). Trips the kill switch automatically.
DAILY_LOSS_LIMIT_USD=500

# Per-trade sizing caps
HARD_CAP_USD=200
MIN_EDGE_CENTS=1.0
SLIPPAGE_BUFFER_CENTS=0.5
MIN_EXPECTED_PROFIT_USD=0.50
KELLY_FRACTION=0.5

# Market universe selection
UNIVERSE_LOOKBACK_HOURS=24
UNIVERSE_MIN_VOLUME_USD=1000
UNIVERSE_CATEGORIES=crypto,weather,econ

# Scanner cadence
SCANNER_MIN_HALT_RECOVER_SEC=5
SCANNER_EMPTY_BOOK_HALT_SEC=2

# WS sharding
WS_MAX_TICKERS_PER_CONN=100

# Data retention
EVENT_STORE_RETENTION_DAYS=90
EVENT_STORE_PATH=./data/kalshi.db

# Store backend: 'sqlite' (default, local file) or 'libsql' (Turso).
# Paper phase on laptop uses sqlite. Fly-hosted dashboard uses libsql
# with embedded replica -- see docs/turso-setup.md.
STORE_BACKEND=sqlite
LIBSQL_URL=
LIBSQL_AUTH_TOKEN=
LIBSQL_SYNC_URL=
LIBSQL_LOCAL_PATH=./data/replica.db

# Dashboard auth
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme
DASHBOARD_PORT=5100

# Auto-publish probe results back to GitHub (for remote verification)
AUTO_PUBLISH=true
AUTO_PUBLISH_BRANCH=kalshi-arb-data
