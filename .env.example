# === Polymarket Copy-Trading Bot Configuration ===

# Mode: set to "false" for live trading
PAPER_MODE=true

# Paper mode starting balance
PAPER_INITIAL_BALANCE_USDC=10000.0

# --- API Keys ---
# Polygon RPC WebSocket (Alchemy or QuickNode)
POLYGON_RPC_WS=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_API_KEY=

# Dune Analytics (for wallet ranking)
DUNE_API_KEY=

# Polymarket CLOB API
POLY_API_KEY=
POLY_PRIVATE_KEY=

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Trading Parameters ---
MIN_WALLET_WIN_RATE=0.70
MIN_MARKET_LIQUIDITY_USDC=50000
MAX_ODDS_SLIPPAGE=0.04
COPY_THRESHOLD=0.60
BASE_COPY_PCT=0.03
MAX_SINGLE_POSITION_PCT=0.08
MIN_TRADE_SIZE_USDC=2.0
MAX_TRADE_SIZE_USDC=1000.0

# --- Risk Management ---
DAILY_LOSS_LIMIT_PCT=0.15
DRAWDOWN_KILL_SWITCH_PCT=0.35
MAX_CONCURRENT_POSITIONS=8
MAX_CATEGORY_EXPOSURE_PCT=0.30
CONSECUTIVE_LOSSES_KILL=8

# --- Exit Rules ---
STOP_LOSS_PCT=0.50
EXIT_TIME_BUFFER_SECONDS=60

# --- Wallet Ranking ---
WALLET_REFRESH_INTERVAL_HOURS=6
MIN_WALLET_SCORE=0.65

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=bot.log
