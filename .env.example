# === Polymarket Latency Arbitrage Bot ===

# --- Mode ---
PAPER_MODE=true

# --- Polymarket CLOB API ---
# Get your API key at https://docs.polymarket.com
POLY_API_KEY=
POLY_PRIVATE_KEY=

# --- Polygon RPC ---
# Get a fast WebSocket endpoint from Alchemy or QuickNode
# Speed matters — this is a latency game
POLYGON_RPC_WS=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_API_KEY=

# --- CEX Price Feeds ---
# These are public endpoints, no API key needed
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com

# --- Edge Detection ---
# Minimum price divergence to trigger a trade (3% = 0.03)
EDGE_THRESHOLD_PCT=0.03
# Maximum divergence (>15% means something is broken)
MAX_EDGE_PCT=0.15
# Confirmation window in milliseconds
CONFIRMATION_WINDOW_MS=500
# Minimum seconds before contract expires
MIN_CONTRACT_DURATION_SECONDS=60

# --- Target Markets ---
# Assets to arbitrage (BTC and ETH short-duration contracts)
TARGET_ASSETS=BTC,ETH
# Contract durations in minutes
TARGET_DURATIONS=15,60

# --- Position Sizing ---
BASE_COPY_PCT=0.05
MAX_SINGLE_POSITION_PCT=0.08
MIN_TRADE_SIZE_USDC=1.0
MAX_TRADE_SIZE_USDC=500.0

# --- Risk Management ---
DAILY_LOSS_LIMIT_PCT=0.20
DRAWDOWN_KILL_SWITCH_PCT=0.40
MAX_CONCURRENT_POSITIONS=5
CONSECUTIVE_LOSSES_KILL=8

# --- Exit ---
STOP_LOSS_PCT=0.50
EXIT_TIME_BUFFER_SECONDS=30

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=bot.log

# --- Paper Mode ---
PAPER_INITIAL_BALANCE_USDC=10000.0
