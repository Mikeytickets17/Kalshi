# === Kalshi Longshot Bias Trading Bot Configuration ===

# --- Mode ---
# Set to "false" for live trading (DANGER: real money)
PAPER_MODE=true

# Paper mode starting balance
PAPER_INITIAL_BALANCE_USDC=10000.0

# --- Kalshi API Credentials ---
# 1. Go to https://kalshi.com/settings (or https://demo.kalshi.com/settings for demo)
# 2. Navigate to "API Keys"
# 3. Create a new API key — copy the Key ID
# 4. Download the private key .pem file and save it locally
# 5. Set the values below:
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Use demo environment (safe for testing, no real money)
# Set to "false" only when ready for production trading
KALSHI_USE_DEMO=true

# --- Telegram Notifications (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Market Scanning ---
# How often to scan for new opportunities (seconds)
SCAN_INTERVAL_SECONDS=300

# Minimum market volume in USD to consider
MIN_MARKET_VOLUME=2000

# Longshot bias: scan for YES contracts priced BELOW this (in sports/entertainment)
LONGSHOT_MAX_PRICE=0.15

# Favorite bias: scan for YES contracts priced ABOVE this (in economics/politics)
FAVORITE_MIN_PRICE=0.70

# Categories to scan for longshots (comma-separated)
LONGSHOT_CATEGORIES=sports,entertainment

# Categories to scan for favorites (comma-separated)
FAVORITE_CATEGORIES=economics,politics

# --- Signal Evaluation ---
# Minimum confidence score to place a trade (0.0 to 1.0)
SIGNAL_THRESHOLD=0.55

# Minimum time remaining before market close (seconds)
MIN_TIME_REMAINING_SECONDS=300

# --- Position Sizing ---
BASE_COPY_PCT=0.03
MAX_SINGLE_POSITION_PCT=0.08
MIN_TRADE_SIZE_USDC=2.0
MAX_TRADE_SIZE_USDC=1000.0

# --- Risk Management ---
DAILY_LOSS_LIMIT_PCT=0.15
DRAWDOWN_KILL_SWITCH_PCT=0.35
MAX_CONCURRENT_POSITIONS=8
MAX_CATEGORY_EXPOSURE_PCT=0.30
CONSECUTIVE_LOSSES_KILL=8

# --- Exit Rules ---
STOP_LOSS_PCT=0.50
EXIT_TIME_BUFFER_SECONDS=60

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=bot.log
