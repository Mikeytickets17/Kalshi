# === Kalshi Multi-Strategy Trading Bot ===
# Copy this to .env and fill in your keys

# --- Mode ---
PAPER_MODE=true

# --- Kalshi API (required for real trading) ---
# Create account at kalshi.com, go to Settings > API
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_USE_DEMO=true

# --- AI Sentiment Analysis (pick ONE — first available is used) ---
# Option 1: Anthropic Claude (best, paid ~$0.001/analysis)
ANTHROPIC_API_KEY=
# Option 2: Groq (FREE — runs Llama 3.1 70B, get key at console.groq.com)
GROQ_API_KEY=
# Option 3: Google Gemini (FREE 15 req/min — get key at aistudio.google.com)
GEMINI_API_KEY=
# Option 4: Ollama (100% FREE — install ollama, run "ollama pull llama3.1")
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Option 5: OpenRouter (some free models — get key at openrouter.ai)
OPENROUTER_API_KEY=
# If none set → falls back to built-in rule-based analysis (still works!)

# --- Brave Search API (FREE tier — real-time web search for breaking news) ---
# Get key at: https://api.search.brave.com/app/keys
BRAVE_API_KEY=

# --- Twitter/X API (optional — adds Trump tweet monitoring) ---
# Get Bearer Token at: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=
TWITTER_TRUMP_USER_ID=25073877

# --- Binance (optional — for BTC/ETH spot trading) ---
# Price feeds work WITHOUT a key (public WebSocket)
# Key only needed for actual trade execution
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# --- Alpaca (optional — for US stock trading) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# --- Telegram (optional — push notifications to your phone) ---
# Message @BotFather on Telegram to create a bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- CEX Price Feeds (free, no key needed) ---
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
COINBASE_WS_URL=wss://ws-feed.exchange.coinbase.com

# --- Edge Detection ---
EDGE_THRESHOLD_PCT=0.03
MAX_EDGE_PCT=0.15
CONFIRMATION_WINDOW_MS=500

# --- Target Markets ---
TARGET_ASSETS=BTC,ETH
TARGET_DURATIONS=15,60

# --- Position Sizing ---
BASE_COPY_PCT=0.05
MAX_SINGLE_POSITION_PCT=0.08
MIN_TRADE_SIZE_USDC=1.0
MAX_TRADE_SIZE_USDC=500.0

# --- Trump Trading ---
TRUMP_POLL_INTERVAL_SECONDS=3.0
TRUMP_MIN_CONFIDENCE=0.45
TRUMP_TRADE_SIZE_PCT=0.06
TRUMP_MAX_TRADE_SIZE_USDC=750.0
TRUMP_HOLD_MINUTES=20

# --- Risk Management ---
DAILY_LOSS_LIMIT_PCT=0.20
DRAWDOWN_KILL_SWITCH_PCT=0.40
MAX_CONCURRENT_POSITIONS=5
CONSECUTIVE_LOSSES_KILL=8
STOP_LOSS_PCT=0.50

# --- Paper Mode ---
PAPER_INITIAL_BALANCE_USDC=10000.0

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=bot.log
